  },
  {
   "yr": 1960,
   "ev": "Debuts on The Ed Sullivan Show with her Thanksgiving turkey routine"
  },
  {
   "yr": 1966,
   "ev": "Co-stars with Bob Hope in Boy, Did I Get a Wrong Number!"
  },
  {
   "yr": 1967,
   "ev": "Becomes a semi-regular on The Hollywood Squares"
  },
  {
   "yr": 2002,
   "ev": "Gives her final stand-up performance in Las Vegas"
  }
 ],
